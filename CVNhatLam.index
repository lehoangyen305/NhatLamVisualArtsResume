<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nhat Lam Nguyen | Visual Artist & Engineer Portfolio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Urbanist:wght@300;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        :root { --gold: #C5A059; --dark: #050505; --accent: #111; --text: #f0f0f0; --gray: #888; }
        
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background-color: #000; color: var(--text); font-family: 'Urbanist', sans-serif; line-height: 1.6; }
        
        .container { max-width: 1100px; margin: 0 auto; padding: 0 30px; }

        /* PDF Header Style */
        header { 
            height: 90vh; 
            display: flex; 
            flex-direction: column; 
            justify-content: center; 
            align-items: center; 
            text-align: center; 
            background: linear-gradient(rgba(0,0,0,0.7), var(--dark)), url('art5.jpg') center/cover;
            border-bottom: 2px solid var(--gold);
        }
        header h1 { font-size: clamp(50px, 8vw, 100px); font-weight: 700; letter-spacing: -2px; line-height: 0.9; margin-bottom: 20px; }
        header h1 span { color: var(--gold); }
        .tagline { font-size: 18px; letter-spacing: 5px; color: var(--gold); text-transform: uppercase; }

        /* Unified Sections */
        section { padding: 100px 0; border-bottom: 1px solid #222; }
        .section-title { font-size: 36px; margin-bottom: 50px; color: #fff; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; }
        .section-title::after { content: ''; display: block; width: 50px; height: 3px; background: var(--gold); margin-top: 10px; }

        /* The Vision / Intro */
        .vision-text { font-size: 24px; color: #bbb; max-width: 900px; margin-bottom: 40px; }
        .vision-text span { color: var(--gold); font-weight: 700; }

        /* Project Showcase (Portfolio) */
        .project-list { display: flex; flex-direction: column; gap: 100px; }
        .project-box { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 50px; align-items: start; }
        .project-media img { width: 100%; border: 1px solid #333; box-shadow: 0 20px 40px rgba(0,0,0,0.5); }
        .project-info h3 { font-size: 30px; color: var(--gold); margin-bottom: 15px; }
        
        /* Process/Sketch component */
        .sketch-flow { margin: 25px 0; padding: 20px; background: rgba(197, 160, 89, 0.05); border-left: 2px solid var(--gold); }
        .sketch-flow-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 15px; }
        .sketch-img { opacity: 0.6; filter: grayscale(100%); transition: 0.4s; cursor: pointer; border: 1px solid #444; width: 100%; }
        .sketch-img:hover { opacity: 1; filter: grayscale(0%); }
        .sketch-label { font-size: 12px; color: var(--gold); text-transform: uppercase; letter-spacing: 1px; }

        /* Experience & CV Grid */
        .cv-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 60px; }
        .exp-item { margin-bottom: 40px; border-left: 1px solid #333; padding-left: 20px; }
        .exp-head { display: flex; justify-content: space-between; margin-bottom: 10px; }
        .exp-head h4 { font-size: 20px; color: #fff; }
        .exp-head .date { color: var(--gold); font-weight: 700; font-size: 14px; }
        
        /* Skills glassmorphism */
        .skills-card { background: #0a0a0a; border: 1px solid #222; padding: 40px; border-radius: 4px; position: sticky; top: 50px; }
        .skill-group { margin-bottom: 30px; }
        .skill-group h5 { font-size: 13px; color: var(--gold); text-transform: uppercase; margin-bottom: 15px; letter-spacing: 1px; border-bottom: 1px solid #222; padding-bottom: 5px; }
        .tag-cloud { display: flex; flex-wrap: wrap; gap: 10px; }
        .tag { background: #1a1a1a; padding: 5px 12px; font-size: 11px; border: 1px solid #333; color: #ccc; }

        /* Academic Merit */
        .academic-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 50px; }
        .stat-card { background: #0a0a0a; padding: 30px; text-align: center; border: 1px solid #1a1a1a; }
        .stat-card h4 { font-size: 40px; color: var(--gold); margin-bottom: 5px; }
        .stat-card p { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--gray); }

        /* Footer */
        footer { padding: 100px 0; text-align: center; background: #020202; }
        .cta-btn { 
            display: inline-block; padding: 15px 40px; border: 1px solid var(--gold); 
            color: var(--gold); text-decoration: none; text-transform: uppercase; 
            letter-spacing: 3px; font-size: 14px; transition: 0.3s; margin-bottom: 40px;
        }
        .cta-btn:hover { background: var(--gold); color: #000; }
        .socials a { color: var(--gray); font-size: 26px; margin: 0 20px; transition: 0.3s; }
        .socials a:hover { color: var(--gold); }

        @media (max-width: 968px) {
            .project-box, .cv-grid, .academic-stats { grid-template-columns: 1fr; }
            header h1 { font-size: 60px; }
        }
    </style>
</head>
<body>

    <header>
        <p class="tagline">Visual Artist & Engineer</p>
        <h1>NHAT LAM <span>NGUYEN</span></h1>
        <p style="opacity: 0.5; margin-top: 15px; font-size: 14px; letter-spacing: 2px;">THE INTERSECTION OF LOGIC & ART</p>
    </header>

    <div class="container">
        
        <section id="vision">
            <h2 class="section-title">The Vision</h2>
            <p class="vision-text">
                Leveraging <span>Mechanical Physics</span> from HUST to drive digital motion. I bridge the gap between technical rigor and visual storytelling, creating experiences that resonate with <span>cultural familiarity</span>.
            </p>
        </section>

        <section id="portfolio">
            <h2 class="section-title">Selected Works</h2>
            <div class="project-list">

                <div class="project-box">
                    <div class="project-media"><img src="art1.jpg" alt="Mobius 2022"></div>
                    <div class="project-info">
                        <h3>Mobius 2022: Luxury Maturity</h3>
                        <p>Branding for high-achieving cohorts. Replaced laurels with <em>Snow Chrysanthemum</em> to preserve student-like innocence.</p>
                        
                        <div class="sketch-flow">
                            <p class="sketch-label">Development: Sketch to Final</p>
                            <div class="sketch-flow-grid">
                                <img src="mobius22_sketch.jpg" class="sketch-img" alt="Sketch 22">
                                <p style="font-size: 13px; color: var(--gray);">Applied <strong>Velvet Textures</strong> and wisdom-themed tones to celebrate the academic process.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="project-box">
                    <div class="project-media"><img src="art2.jpg" alt="Mobius 2023"></div>
                    <div class="project-info">
                        <h3>Mobius 2023: Freedom</h3>
                        <p>Focusing on liberation. Utilizing birds in flight against an expansive sky to represent the boundless future of graduates.</p>
                        
                        <div class="sketch-flow">
                            <p class="sketch-label">Concept: Sky Metaphor</p>
                            <div class="sketch-flow-grid">
                                <img src="mobius23_sketch.jpg" class="sketch-img" alt="Sketch 23">
                                <p style="font-size: 13px; color: var(--gray);">Minimalist layout to maximize the sense of <strong>Open Potential</strong>.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="project-box">
                    <div class="project-media"><img src="art3.jpg" alt="Mid-Autumn"></div>
                    <div class="project-info">
                        <h3>Bright Moon Festival</h3>
                        <p>A contemporary lens on tradition. Blending heritage patterns with modern twilight gradients for youth-focused engagement.</p>
                    </div>
                </div>

                <div class="project-box">
                    <div class="project-media"><img src="art4.jpg" alt="Trạm Ký Ức"></div>
                    <div class="project-info">
                        <h3>Station of Memories</h3>
                        <p>Cinematic storytelling of Lunar New Year eras. Utilizing <strong>Perspective Blending</strong> to unite past and present architecture.</p>
                    </div>
                </div>

                <div class="project-box">
                    <div class="project-media"><img src="art5.jpg" alt="Horror Installation"></div>
                    <div class="project-info">
                        <h3>Run Away Installation</h3>
                        <p>Psychological horror. Hand-sculpted foam limbs and crimson LEDs designed to evoke a visceral sense of dread.</p>
                    </div>
                </div>

            </div>
        </section>

        <section id="cv">
            <h2 class="section-title">Curriculum Vitae</h2>
            <div class="cv-grid">
                
                <div class="experience-list">
                    <div class="exp-item">
                        <div class="exp-head">
                            <h4>Design Lead | Mobius Projects</h4>
                            <span class="date">2022 - 2023</span>
                        </div>
                        <p style="color: var(--gray);">Managed a creative team of 4 for full-scale visual identity production. Directed concept sketching and color theory application.</p>
                    </div>

                    <div class="exp-item">
                        <div class="exp-head">
                            <h4>Team Lead | House Hephaestus</h4>
                            <span class="date">First Sight Event</span>
                        </div>
                        <p style="color: var(--gray);">Directed 64 students to a Top 7 finish. Coordinated performances, logistics, and cohort morale.</p>
                    </div>

                    <div class="exp-item">
                        <div class="exp-head">
                            <h4>Volunteer | To He Project</h4>
                            <span class="date">Social Impact</span>
                        </div>
                        <p style="color: var(--gray);">Nutritional support and creative workshops for pediatric patients at the National Children's Hospital.</p>
                    </div>
                </div>

                <div class="skills-sidebar">
                    <div class="skills-card">
                        <div class="skill-group">
                            <h5>Visual Art</h5>
                            <div class="tag-cloud">
                                <span class="tag">Character Design</span>
                                <span class="tag">Concept Art</span>
                                <span class="tag">Pencil Study</span>
                            </div>
                        </div>
                        <div class="skill-group">
                            <h5>Tech Stack</h5>
                            <div class="tag-cloud">
                                <span class="tag">Photoshop</span>
                                <span class="tag">After Effects</span>
                                <span class="tag">HTML/CSS</span>
                            </div>
                        </div>
                        <div class="skill-group">
                            <h5>Languages</h5>
                            <p style="font-size: 14px; font-weight: 700; color: var(--gold);">English (IELTS/SAT Certified)</p>
                            <p style="font-size: 13px; opacity: 0.6;">Vietnamese (Native)</p>
                        </div>
                    </div>
                </div>

            </div>

            <div class="academic-stats">
                <div class="stat-card">
                    <h4>8.7</h4>
                    <p>Year 12 GPA (LTV)</p>
                </div>
                <div class="stat-card">
                    <h4>Top 5</h4>
                    <p>English Merit Award</p>
                </div>
                <div class="stat-card">
                    <h4>Top 10</h4>
                    <p>Physics Merit Award</p>
                </div>
            </div>
        </section>

    </div>

    <footer>
        <a href="mailto:lam.nguyen.art@gmail.com" class="cta-btn">Start a Collaboration</a>
        <div class="socials">
            <a href="mailto:lam.nguyen.art@gmail.com"><i class="fa-solid fa-envelope"></i></a>
            <a href="https://github.com/lehoangyen305"><i class="fa-brands fa-github"></i></a>
            <a href="#"><i class="fa-brands fa-instagram"></i></a>
        </div>
        <p style="margin-top: 50px; font-size: 11px; opacity: 0.3; letter-spacing: 2px;">&copy; 2026 NHAT LAM NGUYEN | HANOI UNIVERSITY OF SCIENCE & TECH</p>
    </footer>

</body>
</html>
